# ══════════════════════════════════════════════════════
#  AT Gaming — Konfiguracja środowiskowa
#  Skopiuj ten plik jako .env i uzupełnij wartości
# ══════════════════════════════════════════════════════

# ── DISCORD OAUTH2 (opcjonalne) ──────────────────────
# Pobierz z: https://discord.com/developers/applications
# Instrukcja: https://github.com/twoja-repo#discord-setup

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# ── BEZPIECZEŃSTWO ────────────────────────────────────
# Zmień na losowy ciąg znaków dla bezpieczeństwa sesji!
SESSION_SECRET=zmien-to-na-losowy-ciag-znakow

# ── SERWER ────────────────────────────────────────────
PORT=3000
ADMIN_PASSWORD=admin123
